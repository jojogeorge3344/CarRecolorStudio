{
  "openapi": "3.0.4",
  "info": {
    "title": "Car Colour Project",
    "version": "1.0"
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Car Colour Project"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Cars": {
      "get": {
        "tags": [
          "Cars"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Cars/search": {
      "get": {
        "tags": [
          "Cars"
        ],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Colors": {
      "get": {
        "tags": [
          "Colors"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Colors/search": {
      "get": {
        "tags": [
          "Colors"
        ],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Recolor": {
      "post": {
        "tags": [
          "Recolor"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecolorRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RecolorRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RecolorRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/RecolorResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecolorResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecolorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RecolorRequest": {
        "required": [
          "carId",
          "hexColor"
        ],
        "type": "object",
        "properties": {
          "carId": {
            "minLength": 1,
            "type": "string"
          },
          "hexColor": {
            "minLength": 1,
            "pattern": "^#(?:[0-9a-fA-F]{3}){1,2}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RecolorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "imageUrl": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Car Colour Project"
    },
    {
      "name": "Cars"
    },
    {
      "name": "Colors"
    },
    {
      "name": "Recolor"
    }
  ]
}