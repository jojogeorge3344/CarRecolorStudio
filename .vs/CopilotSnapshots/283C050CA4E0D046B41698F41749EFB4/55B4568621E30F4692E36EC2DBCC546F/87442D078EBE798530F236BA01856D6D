const state = {
    cars: [],
    colors: [],
    filteredColors: [],
    selectedCar: null,
    selectedColor: null,
    recent: []
};

const maxRecent = 20;

const elements = {
    carSearch: document.getElementById('carSearch'),
    carSuggestions: document.getElementById('carSuggestions'),
    colorSearch: document.getElementById('colorSearch'),
    customHex: document.getElementById('customHex'),
    categoryFilter: document.getElementById('categoryFilter'),
    colorList: document.getElementById('colorList'),
    recentColors: document.getElementById('recentColors'),
    selectedCarLabel: document.getElementById('selectedCarLabel'),
    selectedColorLabel: document.getElementById('selectedColorLabel'),
    originalImage: document.getElementById('originalImage'),
    recoloredImage: document.getElementById('recoloredImage'),
    sliderOriginal: document.getElementById('sliderOriginal'),
    sliderRecolored: document.getElementById('sliderRecolored'),
    sliderOverlay: document.getElementById('sliderOverlay'),
    compareSlider: document.getElementById('compareSlider'),
    zoomRange: document.getElementById('zoomRange'),
    viewer: document.getElementById('viewer'),
    fullscreenBtn: document.getElementById('fullscreenBtn')
};

init();

async function init() {
    state.recent = loadRecent();
    renderRecent();

    const [cars, colors] = await Promise.all([
        fetchJson('/api/cars'),
        fetchJson('/api/colors')
    ]);

    state.cars = cars;
    state.colors = colors;

    renderCarSuggestions(cars);
    renderCategoryFilter(colors);
    applyColorFilter();

    if (cars.length > 0) {
        selectCar(cars[0].id);
    }

    wireEvents();
}

function wireEvents() {
    elements.carSearch.addEventListener('input', debounce(async e => {
        const term = e.target.value.trim();
        const cars = term ? await fetchJson(`/api/cars/search?term=${encodeURIComponent(term)}`) : state.cars;
        renderCarSuggestions(cars);

        const exact = findCarByInput(term, cars);
        if (exact) {
            selectCar(exact.id);
        }
    }, 150));

    elements.carSearch.addEventListener('change', e => {
        const term = e.target.value.trim();
        const exact = findCarByInput(term, state.cars);
        if (exact) {
            selectCar(exact.id);
        }
    });

    elements.colorSearch.addEventListener('input', debounce(applyColorFilter, 120));
    elements.categoryFilter.addEventListener('change', applyColorFilter);

    elements.customHex.addEventListener('input', e => {
        const value = e.target.value.trim();
        if (/^#(?:[0-9a-fA-F]{3}){1,2}$/.test(value)) {
            applyColor({ name: `Custom ${value.toUpperCase()}`, hex: value.toUpperCase(), category: 'Custom' });
        }
    });

    elements.compareSlider.addEventListener('input', e => {
        elements.sliderOverlay.style.width = `${e.target.value}%`;
    });

    elements.zoomRange.addEventListener('input', e => {
        const scale = Number(e.target.value);
        [elements.originalImage, elements.recoloredImage, elements.sliderOriginal, elements.sliderRecolored].forEach(img => {
            img.style.transform = `scale(${scale})`;
        });
    });

    elements.fullscreenBtn.addEventListener('click', () => {
        if (!document.fullscreenElement) {
            elements.viewer.requestFullscreen();
        } else {
            document.exitFullscreen();
        }
    });
}

function renderCarSuggestions(cars) {
    elements.carSuggestions.innerHTML = '';
    cars.forEach(car => {
        const option = document.createElement('option');
        option.value = getCarDisplayName(car);
        elements.carSuggestions.appendChild(option);
    });
}

function renderCategoryFilter(colors) {
    const categories = [...new Set(colors.map(c => c.category).filter(Boolean))].sort();
    categories.forEach(category => {
        const option = document.createElement('option');
        option.value = category;
        option.textContent = category;
        elements.categoryFilter.appendChild(option);
    });
}

function applyColorFilter() {
    const term = elements.colorSearch.value.trim().toLowerCase();
    const category = elements.categoryFilter.value;

    state.filteredColors = state.colors.filter(c => {
        const matchesTerm = !term
            || c.name.toLowerCase().includes(term)
            || c.hex.toLowerCase().includes(term);
        const matchesCategory = !category || c.category === category;
        return matchesTerm && matchesCategory;
    });

    renderColorList(state.filteredColors.slice(0, 1000));
}

function renderColorList(colors) {
    elements.colorList.innerHTML = '';
    colors.forEach(color => {
        const row = document.createElement('div');
        row.className = `color-item${state.selectedColor?.hex === color.hex ? ' active' : ''}`;

        const swatch = document.createElement('span');
        swatch.className = 'swatch';
        swatch.style.background = color.hex;

        const label = document.createElement('span');
        label.textContent = `${color.name} (${color.hex})`;

        row.appendChild(swatch);
        row.appendChild(label);
        row.addEventListener('click', () => applyColor(color));

        elements.colorList.appendChild(row);
    });
}

function renderRecent() {
    elements.recentColors.innerHTML = '';
    state.recent.forEach(item => {
        const chip = document.createElement('button');
        chip.className = 'recent-chip';
        chip.title = item.hex;
        chip.style.background = item.hex;
        chip.addEventListener('click', () => applyColor(item));
        elements.recentColors.appendChild(chip);
    });
}

function selectCar(carId) {
    const car = state.cars.find(c => c.id === carId);
    if (!car) {
        return;
    }

    state.selectedCar = car;
    const source = `/images/${toImageKey(car)}.png`;
    elements.originalImage.src = source;
    elements.recoloredImage.src = source;
    elements.sliderOriginal.src = source;
    elements.sliderRecolored.src = source;
    elements.selectedCarLabel.textContent = `Selected Car: ${getCarDisplayName(car)}`;
}

async function applyColor(color) {
    if (!state.selectedCar) {
        return;
    }

    state.selectedColor = color;
    elements.selectedColorLabel.textContent = `Selected Color: ${color.name}`;

    pushRecent(color);
    renderRecent();
    renderColorList(state.filteredColors.slice(0, 1000));

    const response = await fetch('/api/recolor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ carId: state.selectedCar.id, hexColor: color.hex })
    });

    const result = await response.json();
    if (!result.success) {
        return;
    }

    const imageUrl = `${result.imageUrl}?v=${Date.now()}`;
    elements.recoloredImage.src = imageUrl;
    elements.sliderRecolored.src = imageUrl;
}

function pushRecent(color) {
    const normalized = { name: color.name, hex: color.hex.toUpperCase(), category: color.category || 'Custom' };
    state.recent = [normalized, ...state.recent.filter(c => c.hex !== normalized.hex)].slice(0, maxRecent);
    localStorage.setItem('recentColors', JSON.stringify(state.recent));
}

function loadRecent() {
    try {
        const value = localStorage.getItem('recentColors');
        return value ? JSON.parse(value) : [];
    } catch {
        return [];
    }
}

function getCarDisplayName(car) {
    return `${car.brand} ${car.model}`;
}

function toImageKey(car) {
    return `${car.brand}-${car.model}`.toLowerCase().replace(/\s+/g, '-');
}

function findCarByInput(value, cars) {
    const normalized = value.toLowerCase();
    return cars.find(c => getCarDisplayName(c).toLowerCase() === normalized || c.id.toLowerCase() === normalized);
}

async function fetchJson(url) {
    const response = await fetch(url);
    if (!response.ok) {
        throw new Error(`Request failed: ${url}`);
    }

    return response.json();
}

function debounce(action, delay) {
    let timeout;
    return (...args) => {
        clearTimeout(timeout);
        timeout = setTimeout(() => action(...args), delay);
    };
}
