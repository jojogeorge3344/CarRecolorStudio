/* ═══════════════════════════════════════════
   TOKENS & RESET
═══════════════════════════════════════════ */
:root {
    --font:         'Inter', 'Segoe UI', Arial, sans-serif;

    /* Brand palette */
    --accent:       #6c63ff;
    --accent-dark:  #4f46e5;
    --accent-glow:  rgba(108, 99, 255, 0.25);

    /* Backgrounds */
    --bg-body:      #0f1117;
    --bg-panel:     #181b26;
    --bg-card:      #1f2336;
    --bg-input:     #252a3a;
    --bg-hover:     #2a2f42;

    /* Borders */
    --border:       rgba(255,255,255,.08);
    --border-focus: rgba(108,99,255,.6);

    /* Text */
    --text-primary: #f0f2ff;
    --text-muted:   #8b93b0;
    --text-dim:     #555d7a;

    /* Status / feedback */
    --success:      #22c55e;
    --warning:      #f59e0b;

    /* Layout */
    --sidebar-w:    380px;
    --radius-sm:    8px;
    --radius-md:    14px;
    --radius-lg:    20px;

    /* Transitions */
    --ease:         cubic-bezier(.4,0,.2,1);
    --dur:          180ms;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
    font-family: var(--font);
    background: var(--bg-body);
    color: var(--text-primary);
    min-height: 100vh;
    line-height: 1.5;
}

/* ═══════════════════════════════════════════
   HEADER
═══════════════════════════════════════════ */
.app-header {
    background: linear-gradient(135deg, #1a1d2e 0%, #12141f 100%);
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 24px rgba(0,0,0,.4);
}

.header-inner {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    width: 100%;
}

.brand {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -.5px;
    color: var(--text-primary);
}

.brand-icon { font-size: 1.5rem; }
.brand-accent { color: var(--accent); }

.brand-tagline {
    font-size: .78rem;
    color: var(--text-muted);
    margin-left: .85rem;
    font-weight: 500;
}

.module-nav {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    margin-left: auto;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: .2rem;
}

.module-btn {
    border: none;
    background: transparent;
    color: var(--text-muted);
    padding: .35rem .75rem;
    border-radius: 999px;
    font-family: var(--font);
    font-size: .78rem;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
}

.module-btn.active {
    color: #fff;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
}

.module-view {
    min-height: calc(100vh - 64px);
}

/* ═══════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════ */
.layout {
    display: grid;
    grid-template-columns: var(--sidebar-w) 1fr;
    min-height: calc(100vh - 64px);
}

/* ═══════════════════════════════════════════
   PANELS
═══════════════════════════════════════════ */
.panel {
    padding: 1.25rem;
}

.left-panel {
    background: var(--bg-panel);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: .1rem;
    overflow-y: auto;
    max-height: calc(100vh - 64px);
    scrollbar-width: thin;
    scrollbar-color: var(--bg-hover) transparent;
}

.right-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--bg-body);
    padding: 1.25rem;
}

/* ═══════════════════════════════════════════
   SECTION BLOCKS (left panel)
═══════════════════════════════════════════ */
.section-block {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
    margin-bottom: .75rem;
}

.section-block.flex-grow {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
}

.section-title {
    font-size: .9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-muted);
    margin-bottom: .75rem;
}

.section-subtitle {
    font-size: .82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--text-muted);
    margin-bottom: .6rem;
}

/* ═══════════════════════════════════════════
   FORM ELEMENTS
═══════════════════════════════════════════ */
.field-label {
    display: block;
    font-size: .78rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: .35rem;
    margin-top: .65rem;
    text-transform: uppercase;
    letter-spacing: .04em;
}

.field-label:first-child { margin-top: 0; }

/* Shared input / select base */
input[type="text"],
input[type="range"],
select {
    width: 100%;
    font-family: var(--font);
    font-size: .88rem;
    color: var(--text-primary);
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: .55rem .85rem;
    outline: none;
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}

input[type="text"]:focus,
select:focus {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 3px var(--accent-glow);
}

input[type="text"]::placeholder { color: var(--text-dim); }

/* Select wrapper (custom arrow) */
.select-wrapper {
    position: relative;
}

.select-wrapper select {
    appearance: none;
    padding-right: 2.2rem;
    cursor: pointer;
}

.select-arrow {
    position: absolute;
    right: .85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
    font-size: .9rem;
}

/* Input with icon */
.input-wrapper {
    position: relative;
}

.input-wrapper input { padding-left: 2.2rem; }

.input-icon {
    position: absolute;
    left: .75rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: .9rem;
    pointer-events: none;
}

/* HEX row: colour picker + text */
.hex-row {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: .5rem;
    align-items: center;
}

input[type="color"] {
    width: 44px;
    height: 36px;
    padding: 2px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-input);
    cursor: pointer;
    outline: none;
}

input[type="color"]:focus {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 3px var(--accent-glow);
}

/* Range slider */
input[type="range"] {
    padding: 0;
    height: 6px;
    accent-color: var(--accent);
    cursor: pointer;
    border: none;
}

/* ═══════════════════════════════════════════
   CAR INFO BADGE
═══════════════════════════════════════════ */
.car-info-badge {
    margin-top: .6rem;
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
}

.car-info-badge.hidden { display: none; }

.badge {
    display: inline-block;
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    color: #fff;
    padding: .2rem .65rem;
    border-radius: 99px;
}

/* ═══════════════════════════════════════════
   COLOUR LIST
═══════════════════════════════════════════ */
.color-list {
    flex: 1;
    overflow-y: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-input);
    scrollbar-width: thin;
    scrollbar-color: var(--bg-hover) transparent;
}

.color-item {
    display: flex;
    align-items: center;
    gap: .65rem;
    padding: .55rem .75rem;
    border-bottom: 1px solid rgba(255,255,255,.04);
    cursor: pointer;
    transition: background var(--dur) var(--ease);
    user-select: none;
}

.color-item:last-child { border-bottom: none; }

.color-item:hover { background: var(--bg-hover); }

.color-item.active {
    background: linear-gradient(90deg, rgba(108,99,255,.18), rgba(108,99,255,.04));
    border-left: 3px solid var(--accent);
}

.swatch {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 2px solid rgba(255,255,255,.15);
    transition: transform var(--dur) var(--ease);
}

.color-item:hover .swatch { transform: scale(1.2); }

.color-label {
    flex: 1;
    font-size: .84rem;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.color-hex {
    font-size: .72rem;
    font-weight: 600;
    font-family: 'Courier New', monospace;
    color: var(--text-muted);
}

.no-results {
    padding: 1rem;
    text-align: center;
    color: var(--text-dim);
    font-size: .85rem;
}

/* ═══════════════════════════════════════════
   RECENTLY USED
═══════════════════════════════════════════ */
.recent-list {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    min-height: 30px;
    align-items: center;
}

.recent-chip {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,.2);
    cursor: pointer;
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
    background-clip: padding-box;
}

.recent-chip:hover {
    transform: scale(1.25);
    box-shadow: 0 0 0 3px var(--accent-glow);
}

.no-recent {
    font-size: .78rem;
    color: var(--text-dim);
}

/* ═══════════════════════════════════════════
   STATUS BAR
═══════════════════════════════════════════ */
.status-bar {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
}

.status-chip {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: .35rem .9rem;
    font-size: .82rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    max-width: 320px;
    overflow: hidden;
    text-overflow: ellipsis;
}

.status-icon { flex-shrink: 0; }

/* ═══════════════════════════════════════════
   VIEWER CONTROLS
═══════════════════════════════════════════ */
.viewer-controls {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: .75rem;
    align-items: center;
}

.viewer-controls .field-label {
    margin: 0;
    white-space: nowrap;
}

.btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    color: #fff;
    font-family: var(--font);
    font-size: .82rem;
    font-weight: 600;
    border: none;
    border-radius: var(--radius-sm);
    padding: .5rem 1.1rem;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
}

.btn-primary:hover {
    opacity: .9;
    transform: translateY(-1px);
}

.btn-primary:active { transform: translateY(0); }

.btn-primary:disabled,
.btn-secondary:disabled {
    opacity: .55;
    cursor: not-allowed;
    transform: none;
}

.btn-secondary {
    background: var(--bg-input);
    color: var(--text-primary);
    font-family: var(--font);
    font-size: .82rem;
    font-weight: 600;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: .5rem 1rem;
    cursor: pointer;
    transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease);
}

.btn-secondary:hover {
    background: var(--bg-hover);
    border-color: var(--border-focus);
}

.icon-btn {
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 50%;
    background: var(--bg-input);
    color: var(--text-primary);
    cursor: pointer;
    font-size: 1rem;
}

.icon-btn:hover {
    background: var(--bg-hover);
    border-color: var(--border-focus);
}

.paint-tools {
    margin-top: .65rem;
    display: grid;
    grid-template-columns: auto auto auto 1fr auto auto;
    gap: .55rem;
    align-items: center;
}

.paint-label {
    margin: 0;
}

.paint-tool.active {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 2px var(--accent-glow);
}

#paintColorPicker {
    width: 42px;
    height: 34px;
    padding: 1px;
}

/* ═══════════════════════════════════════════
   VIEWER BOX
═══════════════════════════════════════════ */
.viewer {
    flex: 1;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    overflow: auto;
    padding: 1.25rem;
    position: relative;
    scrollbar-width: thin;
    scrollbar-color: var(--bg-hover) transparent;
}

/* ── Empty state ── */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-height: 260px;
    gap: 1rem;
    color: var(--text-dim);
    text-align: center;
}

.empty-icon {
    font-size: 4rem;
    animation: float 3s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
}

.empty-state p {
    font-size: .95rem;
    font-weight: 500;
    color: var(--text-muted);
}

.hidden { display: none !important; }

/* ── Compare area ── */
.compare-area {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

/* ═══════════════════════════════════════════
   SIDE-BY-SIDE IMAGE BOXES
═══════════════════════════════════════════ */
.compare-side-by-side {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
}

.image-box {
    display: flex;
    flex-direction: column;
    gap: .5rem;
}

.image-label {
    font-size: .78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--text-muted);
}

.img-frame {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-input);
    min-height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.img-frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 0;
    border: none;
    transform-origin: top left;
    transition: transform var(--dur) var(--ease);
}

/* Recoloured frame gets a subtle accent border */
.recolored-frame {
    border-color: rgba(108, 99, 255, 0.3);
    box-shadow: 0 0 20px rgba(108, 99, 255, 0.08);
}

.paint-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 6;
    pointer-events: auto;
    cursor: crosshair;
    transform-origin: top left;
}

/* ── Loading spinner overlay ── */
.img-loader {
    position: absolute;
    inset: 0;
    background: rgba(15, 17, 23, 0.7);
    backdrop-filter: blur(4px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    color: var(--text-muted);
    font-size: .82rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    z-index: 10;
}

.spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(108, 99, 255, 0.2);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin .75s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ═══════════════════════════════════════════
   SLIDER COMPARISON
═══════════════════════════════════════════ */
.slider-section {
    display: flex;
    flex-direction: column;
    gap: .6rem;
}

.slider-wrap {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-input);
    user-select: none;
}

.slider-base {
    display: block;
    width: 100%;
    object-fit: contain;
    border-radius: 0;
    border: none;
}

.slider-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 50%;
    height: 100%;
    overflow: hidden;
    border-right: 2px solid var(--accent);
}

.slider-top {
    width: 100%;
    object-fit: contain;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    border-radius: 0;
    border: none;
}

/* Draggable divider handle */
.slider-divider {
    position: absolute;
    top: 0;
    left: 50%;
    width: 28px;
    height: 100%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 5;
}

.slider-divider::before {
    content: '⇔';
    width: 28px;
    height: 28px;
    background: var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .75rem;
    color: #fff;
    box-shadow: 0 2px 10px rgba(108,99,255,.5);
    line-height: 28px;
    text-align: center;
}

/* Range input sits on top of the slider-wrap */
#compareSlider {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: col-resize;
    z-index: 10;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
}

.slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: .72rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: .05em;
    padding: 0 .25rem;
}

/* ═══════════════════════════════════════════
   CAR INFO MODULE
═══════════════════════════════════════════ */
.car-info-layout {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
}

.car-info-card {
    width: min(820px, 100%);
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
}

.car-info-viewer {
    margin-top: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    min-height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}

.car-info-empty {
    min-height: 280px;
}

.car-info-image-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .85rem;
}

.car-info-image-wrap img {
    width: 100%;
    max-width: 700px;
    max-height: 420px;
    object-fit: contain;
}

.car-info-title {
    font-size: .95rem;
    font-weight: 600;
    color: var(--text-muted);
}

.car-search-results {
    margin-top: .5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-input);
    max-height: 200px;
    overflow-y: auto;
}

.car-search-item {
    width: 100%;
    border: none;
    background: transparent;
    color: var(--text-primary);
    text-align: left;
    font-family: var(--font);
    font-size: .85rem;
    padding: .55rem .75rem;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,.05);
}

.car-search-item:last-child {
    border-bottom: none;
}

.car-search-item:hover {
    background: var(--bg-hover);
}

.car-search-empty {
    padding: .7rem .75rem;
    color: var(--text-dim);
    font-size: .8rem;
}

.car-info-actions {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-top: 1rem;
}

.car-details-screen {
    margin-top: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    padding: 1rem;
}

.details-description {
    width: 100%;
    font-family: var(--font);
    font-size: .88rem;
    color: var(--text-primary);
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: .7rem .85rem;
    resize: vertical;
    min-height: 150px;
}

.details-description:focus {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 3px var(--accent-glow);
    outline: none;
}

.word-count {
    margin-top: .4rem;
    font-size: .76rem;
    color: var(--text-muted);
}

.word-count.limit {
    color: #ef4444;
}

.detail-actions-row {
    display: flex;
    flex-wrap: wrap;
    gap: .55rem;
    margin-top: .8rem;
}

.detail-error {
    margin-top: .6rem;
    font-size: .8rem;
    color: #ef4444;
}

.details-list-wrap {
    margin-top: 1rem;
}

.detail-section-list,
.preview-section-list,
.saved-details-list {
    display: flex;
    flex-direction: column;
    gap: .65rem;
    margin-top: .6rem;
}

.detail-item,
.preview-item,
.saved-item {
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: .75rem;
}

.detail-item h4,
.preview-item h4,
.saved-item h4 {
    font-size: .9rem;
    margin-bottom: .35rem;
}

.detail-item p,
.preview-item p,
.saved-item p {
    color: var(--text-muted);
    font-size: .84rem;
    white-space: pre-wrap;
}

.preview-hint {
    color: var(--text-muted);
    font-size: .78rem;
}

.preview-item {
    cursor: grab;
}

.preview-item.dragging {
    opacity: .5;
    border-style: dashed;
}

.preview-item .drag-label {
    font-size: .72rem;
    color: var(--text-dim);
    margin-bottom: .35rem;
    text-transform: uppercase;
    letter-spacing: .04em;
}

/* ═══════════════════════════════════════════
   SCROLLBAR CUSTOM
═══════════════════════════════════════════ */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--bg-hover); border-radius: 99px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-dim); }

/* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */
@media (max-width: 980px) {
    .layout {
        grid-template-columns: 1fr;
    }

    .left-panel {
        max-height: none;
        border-right: none;
        border-bottom: 1px solid var(--border);
    }

    .compare-side-by-side {
        grid-template-columns: 1fr;
    }

    .viewer-controls {
        grid-template-columns: auto 1fr auto auto;
    }

    .paint-tools {
        grid-template-columns: 1fr 1fr;
    }

    .paint-label {
        grid-column: 1 / -1;
    }

    #paintSizeRange {
        grid-column: 1 / -1;
    }

    .module-nav {
        margin-left: 0;
    }

    .brand-tagline { display: none; }
}

@media (max-width: 480px) {
    .status-bar { flex-direction: column; }
    .viewer-controls { grid-template-columns: 1fr 1fr; }
    .viewer-controls .field-label { grid-column: 1 / -1; }
    .btn-primary { grid-column: 1 / -1; }
}
